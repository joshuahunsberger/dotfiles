{{- /* chezmoi:modify-template */ -}}

{{- $settings := dict -}}
{{- if not (empty .chezmoi.stdin) -}}
{{-   $settings = fromJson .chezmoi.stdin -}}
{{- end -}}

{{- /* 1. Ensure Dracula color scheme is present in schemes */ -}}
{{- $draculaScheme := dict "name" "Dracula" "background" "#282A36" "foreground" "#F8F8F2" "cursorColor" "#F8F8F2" "selectionBackground" "#44475A" "black" "#21222C" "blue" "#BD93F9" "cyan" "#8BE9FD" "green" "#50FA7B" "purple" "#FF79C6" "red" "#FF5555" "white" "#F8F8F2" "yellow" "#F1FA8C" "brightBlack" "#6272A4" "brightBlue" "#D6ACFF" "brightCyan" "#A4FFFF" "brightGreen" "#69FF94" "brightPurple" "#FF92DF" "brightRed" "#FF6E6E" "brightWhite" "#FFFFFF" "brightYellow" "#FFFFA5" -}}

{{- $schemes := list -}}
{{- if hasKey $settings "schemes" -}}
{{-   $schemes = $settings.schemes -}}
{{- end -}}
{{- $newSchemes := list -}}
{{- range $schemes -}}
{{-   if ne .name "Dracula" -}}
{{-     $newSchemes = append $newSchemes . -}}
{{-   end -}}
{{- end -}}
{{- $newSchemes = append $newSchemes $draculaScheme -}}
{{- $settings = set $settings "schemes" $newSchemes -}}

{{- /* 2. Set default profile and font in profiles.defaults */ -}}
{{- $profiles := dict -}}
{{- if hasKey $settings "profiles" -}}
{{-   $profiles = $settings.profiles -}}
{{- end -}}
{{- $defaults := dict -}}
{{- if hasKey $profiles "defaults" -}}
{{-   $defaults = $profiles.defaults -}}
{{- end -}}

{{- $defaults = set $defaults "colorScheme" "Dracula" -}}
{{- $font := dict "face" "MesloLGM Nerd Font" -}}
{{- $defaults = set $defaults "font" $font -}}
{{- $profiles = set $profiles "defaults" $defaults -}}
{{- $settings = set $settings "profiles" $profiles -}}

{{- /* 3. Set defaultProfile to PowerShell Core GUID */ -}}
{{- $settings = set $settings "defaultProfile" "{574e775e-4f2a-5b96-ac1e-a2962a402336}" -}}

{{- toPrettyJson $settings -}}
