{{ if eq .chezmoi.os "windows" -}}

# 1. Hash comment: Ensures Chezmoi re-runs this script automatically whenever you edit your profile template!
# Profile Hash: {{ include "Documents/PowerShell/Microsoft.PowerShell_profile.ps1.tmpl" | sha256sum }}

# 2. Where Chezmoi installs your actual managed profile content locally
$managedProfile = "$HOME\Documents\PowerShell\Microsoft.PowerShell_profile.ps1"

# 3. Query Windows for the active My Documents folder (handles Parallels, OneDrive, and domain shares)
$myDocs = [Environment]::GetFolderPath('MyDocuments')

# 4. Define target profile locations for BOTH PowerShell 7 (pwsh) and Windows PowerShell 5.1
$targetProfiles = @(
    "$myDocs\PowerShell\Microsoft.PowerShell_profile.ps1",
    "$myDocs\WindowsPowerShell\Microsoft.PowerShell_profile.ps1"
)

foreach ($target in $targetProfiles) {
    # If the OS-redirected target is different from where Chezmoi manages the file locally
    if ($target -ne $managedProfile) {
        $parentDir = Split-Path -Parent $target
        if (!(Test-Path $parentDir)) {
            New-Item -ItemType Directory -Path $parentDir -Force | Out-Null
        }

        # Create a lightweight dot-source wrapper
        $wrapperContent = "# Auto-generated by Chezmoi to forward to local profile`r`n. `"$managedProfile`""
        Set-Content -Path $target -Value $wrapperContent -Force
        Write-Host "Created profile wrapper: $target -> $managedProfile"
    }
}

{{ end -}}
